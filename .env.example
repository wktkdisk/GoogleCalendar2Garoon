# -----------------------------------------------------------------------
# Google Calendar
# -----------------------------------------------------------------------

# 同期元の Google カレンダー ID (通常は Gmail アドレス)
GOOGLE_CALENDAR_ID=your-name@gmail.com

# -----------------------------------------------------------------------
# Garoon
# -----------------------------------------------------------------------

# Garoon REST API のエンドポイント
GAROON_API=https://your-garoon-host/scripts/cbgrn/grn.exe/api/v1/schedule/events

# Garoon のログイン名
GAROON_USERNAME=your_login_name

# Garoon のパスワード (平文で設定)
GAROON_PASSWORD=your_password

# Garoon でのあなたのユーザーID (数値)
GAROON_USER_ID=9999

# -----------------------------------------------------------------------
# その他
# -----------------------------------------------------------------------

# タイムゾーン (変更不要な場合はそのまま)
TIMEZONE=Asia/Tokyo
